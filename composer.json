{
    "name": "masan27/laravel-redis-om",
    "version": "1.2.1",
    "description": "Laravel Redis OM implementation for Laravel with Direct Redis Access and Python Search Fallback",
    "type": "library",
    "license": "proprietary",
    "homepage": "https://github.com/masan27/laravel-redis-om",
    "support": {
        "source": "https://github.com/masan27/laravel-redis-om"
    },
    "autoload": {
        "psr-4": {
            "Masan27\\LaravelRedisOM\\": "src/"
        }
    },
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/redis": "^11.0|^12.0",
        "illuminate/pagination": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Masan27\\LaravelRedisOM\\RedisOMServiceProvider"
            ]
        }
    }
}

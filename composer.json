{
    "name": "masan27/laravel-redis-om",
    "version": "2.3.0",
    "description": "Laravel Redis OM implementation for Laravel with direct RediSearch support",
    "type": "library",
    "license": "proprietary",
    "homepage": "https://github.com/masan27/laravel-redis-om",
    "support": {
        "source": "https://github.com/masan27/laravel-redis-om"
    },
    "autoload": {
        "psr-4": {
            "Masan27\\LaravelRedisOM\\": "src/"
        }
    },
    "require": {
        "php": "^8.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/redis": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/pagination": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "ramsey/uuid": "^4.7"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Masan27\\LaravelRedisOM\\RedisOMServiceProvider"
            ]
        }
    }
}
